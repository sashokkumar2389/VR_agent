{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Preserve",
        "moduleResolution": "Bundler",
        "types": [
            "node"
        ],
        "lib": [
            "ES2022",
            "DOM"
        ],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": [
        "config/**/*.ts",
        "tests/**/*.ts",
        "utils/**/*.ts",
        "mcp/**/*.ts",
        "reporters/**/*.ts",
        "playwright.config.ts",
        "playwright.validate.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}